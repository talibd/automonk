# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=automonk
POSTGRES_USER=automonk
POSTGRES_PASSWORD=replace-with-strong-password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# App
NODE_ENV=production
PORT=3000
APP_URL=https://automonk.example.com
OPERATOR_PASSWORD=replace-with-strong-password

# Claude AI
ANTHROPIC_API_KEY=sk-ant-...

# Telegram Bot
TELEGRAM_BOT_TOKEN=replace-with-bot-token
TELEGRAM_OPERATOR_CHAT_ID=replace-with-chat-id

# JWT Auth
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=7d

# MinIO / S3 Storage
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key
MINIO_BUCKET=automonk
MINIO_USE_SSL=false

# Platform APIs
IG_APP_ID=
IG_APP_SECRET=
META_APP_ID=
META_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Webhooks
GOOGLE_SHEET_WEBHOOK_SECRET=

# Nango (optional)
NANGO_BASE_URL=https://api.nango.dev
NANGO_SECRET_KEY=
NANGO_WEBHOOK_SECRET=
NANGO_INTEGRATION_INSTAGRAM=
NANGO_INTEGRATION_FACEBOOK=
NANGO_INTEGRATION_LINKEDIN=
NANGO_INTEGRATION_TWITTER=
NANGO_INTEGRATION_THREADS=
NANGO_INTEGRATION_YOUTUBE=
